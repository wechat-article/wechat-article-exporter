# 调试微信代理请求 (仅开发环境(development)支持)
NUXT_DEBUG_MP_REQUEST=false

# AG-Grid 企业版授权
NUXT_AGGRID_LICENSE=

# 导出 HTML/TXT/Markdown/Word 时：true=跳过选文件夹、直接 ZIP（Docker 构建默认 true）；false=始终弹出文件夹
NUXT_PUBLIC_EXPORT_DIRECT_ZIP=

# KV绑定(本地/docker)
NITRO_KV_DRIVER=fs
NITRO_KV_BASE=.data/kv

# Open API（/api/public/**）：私有化默认关闭；如需外部客户端兼容，显式设为 true
NUXT_OPEN_API_ENABLED=false

# KV绑定(cloudflare)
#NITRO_KV_DRIVER=cloudflare-kv-binding

DEBUG_KEY=

# 文档站根 URL；留空则设置页不展示外链（私有化默认留空）
# NUXT_PUBLIC_DOCS_WEBSITE_URL=https://docs.example.com

# wxdown-service 安装包/发布页 URL；留空则不跳转公网，凭证弹窗提示走内部渠道
# NUXT_PUBLIC_WXDOWN_RELEASES_URL=https://example.com/wxdown

# 可选：业务指标收集端点（POST JSON，见 composables/useProductMetrics）
# NUXT_PUBLIC_METRICS_ENDPOINT=

# 可选：LLM adapter（默认关闭；仅服务端读取，禁止使用 NUXT_PUBLIC_* 暴露 key）
# Tencent Lighthouse/Docker 运行时注入规则：
# - 仅在容器运行时或宿主机 shell 环境注入 key，不作为 Docker build arg。
# - 不提交 .env 或 .env.*；当前 .gitignore 仅允许 .env.example。
# - 不新增任何 NUXT_PUBLIC_* provider key。
NUXT_LLM_ENABLED=false
NUXT_LLM_PROVIDER=deepseek
NUXT_LLM_REQUEST_TIMEOUT_MS=30000

# 文章摘要 workflow：disabled | mock | live；live 还需 NUXT_LLM_PROVIDER_CALL_AUTHORIZED=true
NUXT_LLM_ARTICLE_SUMMARY_MODE=disabled
NUXT_LLM_PROVIDER_CALL_AUTHORIZED=false

# Live provider policy gate（生产启用前必须显式确认；默认仅允许本地预检，不代表生产授权）
NUXT_LLM_LIVE_POLICY_ACCEPTED=false
NUXT_LLM_LIVE_MAX_DAILY_CALLS=100
NUXT_LLM_LIVE_MAX_CONCURRENCY=1
NUXT_LLM_LIVE_MAX_RETRIES=0
NUXT_LLM_LIVE_SOURCE_RETENTION=none
NUXT_LLM_LIVE_EVIDENCE_LEVEL=sanitized_metrics_only
NUXT_LLM_LIVE_ROLLBACK_MODE=disabled
NUXT_LLM_LIVE_OBSERVABILITY=local_sanitized

# Kimi / Moonshot；也可使用 KIMI_API_KEY 或 MOONSHOT_API_KEY 作为 fallback
NUXT_LLM_KIMI_API_KEY=
NUXT_LLM_KIMI_BASE_URL=https://api.moonshot.ai/v1
NUXT_LLM_KIMI_MODEL=kimi-k2.6

# DeepSeek；也可使用 DEEPSEEK_API_KEY 作为 fallback
NUXT_LLM_DEEPSEEK_API_KEY=
NUXT_LLM_DEEPSEEK_BASE_URL=https://api.deepseek.com
NUXT_LLM_DEEPSEEK_MODEL=deepseek-v4-flash
