# 调试微信代理请求 (仅开发环境(development)支持)
NUXT_DEBUG_MP_REQUEST=false

# AG-Grid 企业版授权
NUXT_AGGRID_LICENSE=

# KV绑定(本地/docker)
NITRO_KV_DRIVER=fs
NITRO_KV_BASE=.data/kv

# KV绑定(cloudflare)
#NITRO_KV_DRIVER=cloudflare-kv-binding

DEBUG_KEY=
DOCX_OUTPUT_DIR=D:\work\download
# 自动导出的格式（逗号分隔，支持: html,txt,markdown,word,json,excel）
AUTO_EXPORT_FORMATS=word
## PostgreSQL 配置
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE=wae_db

#PG_HOST=localhost
#PG_PORT=23432
#PG_USER=wae_user
#PG_PASSWORD=BigData.2026
#PG_DATABASE=wae_db

# 定时任务配置（按设定天数自动同步文章并生成文档 + Cookie过期提醒）
SCHEDULER_ENABLED=false
# Cron 表达式（默认每天早上8点，时区 Asia/Shanghai）
SCHEDULER_CRON=0 30 8 * * *
# 定时任务每次回溯同步的天数
SCHEDULER_SYNC_DAYS=3

# QQ邮箱 SMTP 配置（用于 Cookie 过期提醒邮件）
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
# QQ邮箱地址
SMTP_USER=1318088750@qq.com
# QQ邮箱 SMTP 授权码（非登录密码，在 QQ邮箱设置-账户-POP3/SMTP服务 中生成）
SMTP_PASS=arckukkhixfghcbc
# 收件人邮箱地址
SMTP_TO=1318088750@qq.com

PORT=3001

# 日志文件输出目录
LOG_DIR=log
# 日志保留天数，超过天数的日志会被自动删除
LOG_RETENTION_DAYS=7
